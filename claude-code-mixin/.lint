exclusions:
  target-promql-rule:
    reason: "Linter does not support LogQL queries."
    entries:
      - panel: "API Calls by Model"
      - panel: "API Request Latency"
      - panel: "Avg Tool Execution Time"
      - panel: "Top Tools Used"
      - panel: "Avg Cost per API Call"
      - panel: "Avg Tokens per API Request"
      - panel: "Events Over Time"
      - panel: "Events"
  target-instance-rule:
    reason: Claude Code OTel metrics do not expose an instance label, so instance is not a relevant filtering dimension for this mixin.
  template-instance-rule:
    reason: Claude Code OTel metrics do not expose an instance label, so instance is not a relevant filtering dimension for this mixin.
