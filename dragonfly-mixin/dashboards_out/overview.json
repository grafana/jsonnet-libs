{
      "links": [
         {
            "keepTime": true,
            "title": "Dragonfly cluster overview",
            "type": "link",
            "url": "/d/dragonfly-cluster-overview"
         }
      ],
      "panels": [
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Dragonfly server uptime in seconds.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "text",
                     "mode": "fixed"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "#5794f2",
                           "value": null
                        }
                     ]
                  },
                  "unit": "s"
               }
            },
            "gridPos": {
               "h": 4,
               "w": 8,
               "x": 0,
               "y": 0
            },
            "id": 1,
            "options": {
               "graphMode": "none",
               "reduceOptions": {
                  "calcs": [
                     "lastNotNull"
                  ]
               }
            },
            "pluginVersion": "v11.0.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "dragonfly_uptime_in_seconds{job=~\"$job\",instance=~\"$instance\",}",
                  "legendFormat": "{{instance}}"
               }
            ],
            "title": "Uptime",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Number of client connections.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "text",
                     "mode": "fixed"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "#5794f2",
                           "value": null
                        }
                     ]
                  },
                  "unit": "short"
               }
            },
            "gridPos": {
               "h": 4,
               "w": 8,
               "x": 8,
               "y": 0
            },
            "id": 2,
            "options": {
               "graphMode": "none",
