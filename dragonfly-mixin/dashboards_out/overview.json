               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "dragonfly_connected_clients{job=~\"$job\",instance=~\"$instance\",}",
                  "legendFormat": "{{instance}}"
               }
            ],
            "title": "Connected clients",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Memory used as percentage of max configured.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "thresholds"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "super-light-green",
                           "value": 0
                        },
                        {
                           "color": "super-light-orange",
                           "value": 80
                        },
                        {
                           "color": "super-light-red",
                           "value": 95
                        }
                     ]
                  },
                  "unit": "percent"
               }
            },
            "gridPos": {
               "h": 4,
               "w": 8,
               "x": 16,
               "y": 0
            },
            "id": 3,
            "options": {
               "graphMode": "none"
            },
            "pluginVersion": "v11.0.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "100 * dragonfly_memory_used_bytes{job=~\"$job\",instance=~\"$instance\",} / clamp_min(dragonfly_memory_max_bytes{job=~\"$job\",instance=~\"$instance\",}, 1)",
                  "legendFormat": "{{instance}}"
               }
            ],
            "title": "Memory utilization",
            "type": "stat"
         },
