      "panels": [
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Current number of client connections waiting on a server connection.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "thresholds"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "super-light-green",
                           "value": 0
                        },
                        {
                           "color": "super-light-orange",
                           "value": 10
                        },
                        {
                           "color": "super-light-red",
                           "value": 20
                        }
                     ]
                  }
               }
            },
            "gridPos": {
               "h": 4,
               "w": 4,
               "x": 0,
               "y": 0
            },
            "id": 1,
            "options": {
               "graphMode": "none"
            },
            "pluginVersion": "v11.4.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "sum(\n  pgbouncer_pools_client_waiting_connections{job=~\"$job\",pgbouncer_cluster=~\"$pgbouncer_cluster\",instance=~\"$instance\",database=~\"$database\"}\n)",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "",
                  "refId": "Client waiting connections"
               }
            ],
            "title": "Client waiting connections",
            "type": "stat"
         },
