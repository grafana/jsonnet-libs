            "fieldConfig": {
               "defaults": {
                  "max": 1,
                  "thresholds": {
                     "steps": [
                        {
                           "color": "super-light-green"
                        },
                        {
                           "color": "super-light-red",
                           "value": 1
                        }
                     ]
                  }
               }
            },
            "gridPos": {
