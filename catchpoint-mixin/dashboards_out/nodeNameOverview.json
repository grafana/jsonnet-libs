            "pluginVersion": "v10.0.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "sum by (node_name) (\n  catchpoint_error_objects_loaded{job=~\"$job\",instance=~\"$instance\",test_name=~\"$test_name\",node_name=~\"$node_name\"}\n)",
