                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "sum(mongodb_connections{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\", state=\"current\"})",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "{{mongodb_cluster}}: Total connections",
