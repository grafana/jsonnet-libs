            ],
            "title": "Total connections",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Total operations per second across all instances.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "fixed"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "#5794f2",
                           "value": null
                        }
                     ]
                  },
                  "unit": "ops"
               }
            },
            "gridPos": {
               "h": 6,
               "w": 4,
               "x": 16,
               "y": 1
            },
            "id": 6,
