                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "max(mongodb_mongod_replset_member_replication_lag{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\"})",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "{{mongodb_cluster}}: Max replication lag",
                  "refId": "Max replication lag"
               }
            ],
            "title": "Max replication lag",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Replica set state per instance over time.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "palette-classic"
                  },
                  "mappings": [
                     {
                        "options": {
                           "0": {
                              "index": 0,
                              "text": "STARTUP"
                           },
                           "1": {
                              "index": 1,
                              "text": "PRIMARY"
                           },
                           "10": {
                              "index": 9,
                              "text": "REMOVED"
                           },
                           "2": {
                              "index": 2,
                              "text": "SECONDARY"
                           },
                           "3": {
                              "index": 3,
                              "text": "RECOVERING"
                           },
                           "5": {
                              "index": 4,
                              "text": "STARTUP2"
                           },
                           "6": {
                              "index": 5,
                              "text": "UNKNOWN"
                           },
                           "7": {
                              "index": 6,
                              "text": "ARBITER"
                           },
                           "8": {
                              "index": 7,
                              "text": "DOWN"
                           },
                           "9": {
                              "index": 8,
                              "text": "ROLLBACK"
                           }
                        },
                        "type": "value"
                     }
                  ],
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [ ]
                  }
               }
            },
            "gridPos": {
               "h": 6,
               "w": 24,
               "x": 0,
               "y": 7
            },
            "id": 8,
            "maxDataPoints": 50,
            "options": {
               "showValue": "auto"
            },
            "pluginVersion": "v11.4.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "avg by (job,mongodb_cluster) (\n  mongodb_mongod_replset_my_state{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\"}\n)",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "{{service_name}}",
                  "refId": "Replica set state"
               }
            ],
            "title": "Instance states",
            "type": "status-history"
         },
