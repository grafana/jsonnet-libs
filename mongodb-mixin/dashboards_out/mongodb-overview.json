                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "count(mongodb_up{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\"} == 0) or vector(0)",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "{{mongodb_cluster}}: Instances down",
                  "refId": "Instances down"
               }
            ],
            "title": "Instances down",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Total current connections across all instances.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
