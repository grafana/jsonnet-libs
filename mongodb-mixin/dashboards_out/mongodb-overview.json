      "panels": [
         {
            "collapsed": false,
            "gridPos": {
               "h": 1,
               "w": 0,
               "x": 0,
               "y": 0
            },
            "id": 1,
            "panels": [ ],
            "title": "Health",
            "type": "row"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Total number of MongoDB instances.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "fixed"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "#5794f2",
                           "value": null
                        }
                     ]
                  }
               }
            },
            "gridPos": {
               "h": 6,
               "w": 4,
               "x": 0,
               "y": 1
            },
            "id": 2,
            "options": {
               "graphMode": "none",
               "reduceOptions": {
                  "calcs": [
                     "lastNotNull"
                  ]
               }
            },
            "pluginVersion": "v11.4.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "count(mongodb_up{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\"})",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "{{mongodb_cluster}}: Total instances",
                  "refId": "Total instances"
               }
            ],
            "title": "Total instances",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Number of MongoDB instances that are up.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "thresholds"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "green",
                           "value": null
                        }
                     ]
                  }
               }
            },
            "gridPos": {
               "h": 6,
               "w": 4,
               "x": 4,
               "y": 1
            },
            "id": 3,
            "options": {
               "graphMode": "none",
               "reduceOptions": {
                  "calcs": [
                     "lastNotNull"
                  ]
               }
            },
            "pluginVersion": "v11.4.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "count(mongodb_up{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\"} == 1) or vector(0)",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "{{mongodb_cluster}}: Instances up",
                  "refId": "Instances up"
               }
            ],
            "title": "Instances up",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Number of MongoDB instances that are down.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "thresholds"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "green",
                           "value": null
                        },
                        {
                           "color": "green",
                           "value": 0
                        },
                        {
                           "color": "red",
                           "value": 1
                        }
                     ]
                  }
               }
            },
            "gridPos": {
               "h": 6,
               "w": 4,
