         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "The uptime of the MongoDB instance.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "fixed"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "#5794f2",
                           "value": null
                        }
                     ]
                  },
                  "unit": "s"
               }
            },
            "gridPos": {
               "h": 6,
               "w": 6,
               "x": 0,
               "y": 1
            },
            "id": 2,
            "options": {
               "graphMode": "none",
               "reduceOptions": {
                  "calcs": [
                     "lastNotNull"
                  ]
               }
            },
            "pluginVersion": "v11.4.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "avg by (job,mongodb_cluster,service_name) (\n  mongodb_instance_uptime_seconds{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\"}\n)",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "{{service_name}}: Uptime",
                  "refId": "Uptime"
               }
            ],
            "title": "Uptime",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "Queries per second.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "fixed"
                  },
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "#5794f2",
                           "value": null
                        }
                     ]
                  },
                  "unit": "ops"
