               "graphMode": "none",
               "reduceOptions": {
                  "calcs": [
                     "lastNotNull"
                  ]
               }
            },
            "pluginVersion": "v11.4.0",
            "targets": [
               {
                  "datasource": {
                     "type": "prometheus",
                     "uid": "${prometheus_datasource}"
                  },
                  "expr": "sum(irate(mongodb_mongod_op_counters_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!=\"command\"}[$__rate_interval]) or irate(mongodb_op_counters_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!=\"command\"}[$__rate_interval]))",
                  "format": "time_series",
                  "instant": false,
                  "legendFormat": "{{service_name}}: QPS",
                  "refId": "QPS"
               }
            ],
            "title": "QPS",
            "type": "stat"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${prometheus_datasource}"
            },
            "description": "An integer between 0 and 10 that represents the replica state of the current member.",
            "fieldConfig": {
               "defaults": {
                  "color": {
                     "fixedColor": "#5794f2",
                     "mode": "fixed"
                  },
                  "mappings": [
                     {
                        "options": {
                           "0": {
                              "index": 0,
                              "text": "STARTUP"
                           },
                           "1": {
                              "index": 1,
                              "text": "PRIMARY"
                           },
                           "10": {
                              "index": 9,
                              "text": "REMOVED"
                           },
                           "2": {
                              "index": 2,
                              "text": "SECONDARY"
                           },
                           "3": {
                              "index": 3,
                              "text": "RECOVERING"
                           },
                           "5": {
                              "index": 4,
                              "text": "STARTUP2"
                           },
                           "6": {
                              "index": 5,
                              "text": "UNKNOWN"
                           },
                           "7": {
                              "index": 6,
                              "text": "ARBITER"
                           },
                           "8": {
                              "index": 7,
                              "text": "DOWN"
                           },
                           "9": {
                              "index": 8,
                              "text": "ROLLBACK"
                           }
                        },
                        "type": "value"
                     }
                  ],
                  "thresholds": {
                     "mode": "absolute",
                     "steps": [
                        {
                           "color": "#5794f2",
                           "value": null
                        }
                     ]
                  }
               }
            },
